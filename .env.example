# MiMo Telegram Bot - Environment Variables
# Copy this file to .env and fill in your values

# [Required] Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=

# [Optional] MiMo execution timeout in seconds (default: 300)
# MIMO_TIMEOUT=300

# [Optional] Comma-separated Telegram user IDs allowed to use the bot
# Leave empty to allow all users
# ALLOWED_USERS=123456789,987654321

# [Optional] Language for Google Speech Recognition (default: zh-CN)
# STT_LANGUAGE=zh-CN
